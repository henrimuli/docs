{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Hivra Help Center",
  "theme": "maple",
  "favicon": "https://hivra.app/logo_icon.png",
  "colors": {
    "primary": "#d89738",
    "light": "#a45c34",
    "dark": "#fbd959"
  },
"navbar": {
  "primary": {
    "type": "button",
    "label": "Visit Website",
    "href": "https://hivra.app"
  }
},
  "navigation": {
    "tabs": [
      {
        "tab": "Hivra Help Center",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "create-account",
              "quickstart"
            ],
            "icon": "rocket-launch"
          },
          {
            "group": "Publishing",
            "pages": [
              "publishing/overview",
              "publishing/composer",
              "publishing/scheduling",
              "publishing/bulk-upload",
              "publishing/approvals",
              "publishing/statuses"
            ],
            "icon": "upload"
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/instagram",
              "integrations/tiktok",
              "integrations/youtube",
              "integrations/facebook",
              "integrations/x-twitter",
              "integrations/threads"
            ],
            "icon": "link"
          },
          {
            "group": "Engagement & Analytics",
            "pages": [
              "engagement/overview",
              "analytics/overview",
              "analytics/export"
            ],
            "icon": "message-dots"
          },
          {
            "group": "Teams & Collaboration",
            "pages": [
              "team/roles",
              "team/invite-members",
              "workspaces",
              "account/plans",
              "account/settings"
            ],
            "icon": "user-group"
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/publishing",
              "troubleshooting/connections",
              "troubleshooting/faq"
            ],
            "icon": "memo-circle-info"
          }
        ]
      }
    ]
  },
  "logo": "/images/logo.png",
  "appearance": {
    "default": "system"
  },
  "search": {
    "prompt": "Search the Hivra Help Center..."
  }
}
