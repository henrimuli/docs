{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Hivra Help Center",
  "theme": "almond",
  "favicon": "https://hivra.app/logo_icon.png",
  "colors": {
    "primary": "#21c721",
    "light": "#21c721",
    "dark": "#21c721"
  },
"navbar": {
  "primary": {
    "type": "button",
    "label": "Start for free",
    "href": "https://hivra.app/signup"
  },
  "links": [
    {
      "href": "https://hivra.app/signup",
      "label": "Start for free"
    }
  ]
},
  "navigation": {
    "tabs": [
      {
        "tab": "Start Here",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "create-account",
              "quickstart"
            ],
            "icon": "rocket-launch"
          },
          {
            "group": "Publishing",
            "pages": [
              "publishing/overview",
              "publishing/composer",
              "publishing/scheduling",
              "publishing/bulk-upload",
              "publishing/approvals",
              "publishing/statuses"
            ],
            "icon": "upload"
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/instagram",
              "integrations/tiktok",
              "integrations/youtube",
              "integrations/facebook",
              "integrations/x-twitter",
              "integrations/threads"
            ],
            "icon": "link"
          },
          {
            "group": "Engagement & Analytics",
            "pages": [
              "engagement/overview",
              "analytics/overview",
              "analytics/export"
            ],
            "icon": "message-dots"
          },
          {
            "group": "Teams & Collaboration",
            "pages": [
              "team/roles",
              "team/invite-members",
              "workspaces"
            ],
            "icon": "user-group"
          },
          {
            "group": "Pricing & Account",
            "icon": "user",
            "pages": [
              "account/plans",
              "account/settings"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/publishing",
              "troubleshooting/connections",
              "troubleshooting/faq"
            ],
            "icon": "memo-circle-info"
          }
        ],
        "icon": "book-open"
      },
      {
        "tab": "Hivra Status",
        "icon": "arrow-up-right-from-square",
        "href": "https://status.hivra.app"
      }
    ]
  },
  "appearance": {
    "default": "system"
  },
  "search": {
    "prompt": "Search the Hivra Help Center..."
  },
  "background": {
    "decoration": "grid"
  }
}
